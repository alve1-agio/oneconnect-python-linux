# OpenConnect VPN Configuration
# Copy this file to .env and fill in your values

# VPN server address
SERVER_URI=https://<your-vpn-server>

# Your company email address
UID_USERNAME=your.email@company.com

# Unique device identifier (generate with: echo -n "$(hostname)-$(date +%s)" | sha256sum | cut -d' ' -f1)
UID_DEVICE=your-generated-device-id-here
